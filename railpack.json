{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "python": "3.13"
  },
  "steps": {
    "install": {
      "commands": [
        "python -m ensurepip --upgrade",
        "pip install --upgrade pip",
        "pip install -r requirements-railway.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port $PORT"
  }
}

